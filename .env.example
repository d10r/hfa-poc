# Relayer configuration
RELAYER_PRIVKEY=0x...
RELAYER_RPC_URL=https://...
RELAYER_ONLY712_MACRO_FORWARDER_ADDRESS=0x...
HOST=localhost
PORT=3000

# Optional: restrict CORS to this origin only. If unset, all origins are allowed.
# CORS_ORIGIN=https://myapp.example.com

# Web Push (VAPID) configuration
# Generate with: npm run generate-vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your-email@example.com

# Database
DATABASE_PATH=./data.db